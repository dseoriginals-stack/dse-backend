{
  "compilerOptions": {
    /* Environment */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Type Checking */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Source Maps */
    "sourceMap": true,

    /* Node Types */
    "types": ["node"],

    /* Build Behavior */
    "noEmitOnError": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}